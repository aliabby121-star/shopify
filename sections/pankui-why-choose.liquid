{{ 'pankui.css' | asset_url | stylesheet_tag }}

<section class="pk pk-why">
  <div class="pk-why__inner">
    {%- if section.settings.heading != blank -%}
      <div class="pk-why__head">
        <h2 class="pk-why__title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="pk-why__grid">
      {%- for block in section.blocks -%}
        <div class="pk-why__card" {{ block.shopify_attributes }}>
          <div class="pk-why__icon">
            {%- case block.settings.icon -%}
            {%- when 'happy' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9 10h.01M15 10h.01"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/></svg>
            {%- when 'cash' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.5"/><path d="M6 9v.01M18 15v.01"/></svg>
            {%- when 'truck' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 5h14v12H1z"/><path d="M15 9h4l3 3v5h-7"/><circle cx="6" cy="19" r="2"/><circle cx="18" cy="19" r="2"/></svg>
            {%- when 'headset' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 14v-3a9 9 0 0 1 18 0v3"/><path d="M21 14v3a2 2 0 0 1-2 2h-2v-6h4zM3 14v3a2 2 0 0 0 2 2h2v-6H3z"/></svg>
            {%- when 'shield' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/></svg>
            {%- endcase -%}
          </div>
          <p class="pk-why__name">{{ block.settings.name }}</p>
          <p class="pk-why__desc">{{ block.settings.desc }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pankui why choose us",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why choose Pankui" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Benefit",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "happy", "label": "Happy face (satisfaction)" },
          { "value": "cash", "label": "Cash (COD)" },
          { "value": "truck", "label": "Truck (shipping)" },
          { "value": "headset", "label": "Headset (support)" },
          { "value": "shield", "label": "Shield (trust)" }
        ], "default": "happy" },
        { "type": "text", "id": "name", "label": "Name", "default": "100% Satisfaction" },
        { "type": "text", "id": "desc", "label": "Description", "default": "Love it or your money back." }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Pankui why choose us",
      "blocks": [
        { "type": "card", "settings": { "icon": "happy", "name": "100% Satisfaction", "desc": "Love it or your money back." } },
        { "type": "card", "settings": { "icon": "cash", "name": "Cash on Delivery", "desc": "Pay when it arrives at your door." } },
        { "type": "card", "settings": { "icon": "truck", "name": "Fast Shipping", "desc": "Dispatched within 24 hours across India." } },
        { "type": "card", "settings": { "icon": "headset", "name": "Live Support", "desc": "Real humans, Mon–Sat 10am–6pm." } }
      ]
    }
  ]
}
{% endschema %}
