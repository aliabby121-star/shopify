{{ 'pankui.css' | asset_url | stylesheet_tag }}

{%- assign steps = 'Confirmed|May 10|✓,Shipped|May 11|✓,Out for delivery|May 12|✓,Delivered|May 13|✓' | split: ',' -%}

<section class="pk pk-page">
  <div class="pk-wrap" style="max-width:760px;">
    <h1 class="pk-tracking__title">Track your order</h1>
    <p class="pk-tracking__meta">Order #PKU1024 &middot; Placed on May 10, 2025</p>

    <div class="pk-tracking__timeline">
      {%- for entry in steps -%}
        {%- assign parts = entry | split: '|' -%}
        <div class="pk-tracking__step is-done">
          <span class="pk-tracking__dot">{{ parts[2] }}</span>
          <span class="pk-tracking__label">{{ parts[0] }}</span>
          <span class="pk-tracking__date">{{ parts[1] }}</span>
        </div>
      {%- endfor -%}
    </div>

    <div class="pk-tracking__details">
      <h3>Order details</h3>
      <div class="pk-tracking__item">
        <div class="pk-cart__thumb">{%- render 'pankui-placeholder', shape: 'spice-rack' -%}</div>
        <div>
          <div class="pk-tracking__item-name">4-Section spice container</div>
          <div class="pk-tracking__item-qty">Qty: 1</div>
        </div>
        <div>₹1,169</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Pankui order tracking", "settings": [], "presets": [{ "name": "Pankui order tracking" }] }
{% endschema %}
