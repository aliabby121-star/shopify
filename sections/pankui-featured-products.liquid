{{ 'pankui.css' | asset_url | stylesheet_tag }}

{%- comment -%} Default placeholder products if no blocks configured {%- endcomment -%}
{%- assign defaults = 'wide-jar|Air-Tight Storage Containers Set|499|799,wide-jar|Fridge Containers (6 Pack)|699|1199,canister|Glass Tea & Sugar Canisters|349|499' | split: ',' -%}

<section class="pk pk-products">
  <div class="pk-products__head">
    <p class="pk-products__eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="pk-products__title">{{ section.settings.heading }}</h2>
  </div>

  <div class="pk-products__grid pk-products__grid--3">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="pk-pcard" {{ block.shopify_attributes }}>
          <div class="pk-pcard__media">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.image.alt | default: block.settings.title }}" loading="lazy">
            {%- else -%}
              {%- render 'pankui-placeholder', shape: block.settings.shape -%}
            {%- endif -%}
            {%- if block.settings.show_sale -%}<span class="pk-pcard__badge">Sale</span>{%- endif -%}
          </div>
          <div class="pk-pcard__body">
            <p class="pk-pcard__title">{{ block.settings.title }}</p>
            <div class="pk-pcard__prices">
              <span class="pk-pcard__price">₹{{ block.settings.price }}</span>
              {%- if block.settings.compare_at != blank -%}
                <span class="pk-pcard__compare">₹{{ block.settings.compare_at }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for entry in defaults -%}
        {%- assign parts = entry | split: '|' -%}
        <a href="/collections/all" class="pk-pcard">
          <div class="pk-pcard__media">
            {%- render 'pankui-placeholder', shape: parts[0] -%}
            <span class="pk-pcard__badge">Sale</span>
          </div>
          <div class="pk-pcard__body">
            <p class="pk-pcard__title">{{ parts[1] }}</p>
            <div class="pk-pcard__prices">
              <span class="pk-pcard__price">₹{{ parts[2] }}</span>
              <span class="pk-pcard__compare">₹{{ parts[3] }}</span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if section.settings.show_view_all -%}
    <div class="pk-products__more">
      <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" class="pk-btn pk-btn--primary">{{ section.settings.view_all_label }} &nbsp;›</a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Pankui featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "MOST LOVED" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Products" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show View All button", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View All label", "default": "View all" },
    { "type": "url", "id": "view_all_link", "label": "View All link" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Product name" },
        { "type": "image_picker", "id": "image", "label": "Image (upload here)" },
        { "type": "select", "id": "shape", "label": "Placeholder shape (used if no image)", "options": [
          { "value": "canister", "label": "Canister" },
          { "value": "wide-jar", "label": "Wide jar" },
          { "value": "spice-rack", "label": "Spice rack" }
        ], "default": "canister" },
        { "type": "text", "id": "price", "label": "Price (₹)", "default": "499" },
        { "type": "text", "id": "compare_at", "label": "Compare-at price (₹) — optional, shows as strikethrough" },
        { "type": "checkbox", "id": "show_sale", "label": "Show Sale badge", "default": true },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{ "name": "Pankui featured products" }]
}
{% endschema %}
