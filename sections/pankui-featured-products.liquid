{{ 'pankui.css' | asset_url | stylesheet_tag }}

{%- comment -%} 10 default placeholder products — Add to Cart button on each card {%- endcomment -%}
{%- assign defaults = 'canister|Universal Wall Phone Holder|199|299,wide-jar|Air-Tight Storage Containers Set|499|799,spice-rack|Bamboo Chopping Board|349|549,wide-jar|Fridge Containers (6 Pack)|699|1199,spice-rack|Stainless Steel Masala Box|449|699,canister|Modular Pantry Jars|349|499,wide-jar|Modular Pantry Set|899|1299,canister|Ceramic Spice Jars|249|399,canister|Oil Sprayer & Dispenser|599|899,wide-jar|Glass Storage Jar|349|499' | split: ',' -%}

<section class="pk pk-products">
  {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
    <div class="pk-products__head">
      {%- if section.settings.eyebrow != blank -%}<p class="pk-products__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="pk-products__title">{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
  {%- endif -%}

  <div class="pk-products__grid pk-products__grid--5">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        {%- capture product_data -%}
          {"id":{{ block.id | json }},"title":{{ block.settings.title | json }},"price":{{ block.settings.price | default: '0' | json }},"compareAt":{{ block.settings.compare_at | default: '' | json }},"image":{%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 200 | json }}{%- else -%}""{%- endif -%}}
        {%- endcapture -%}
        <div class="pk-pcard" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link | default: '/pages/product' }}" style="text-decoration:none; color:inherit;">
            <div class="pk-pcard__media">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.image.alt | default: block.settings.title }}" loading="lazy">
              {%- else -%}
                {%- render 'pankui-placeholder', shape: block.settings.shape -%}
              {%- endif -%}
              {%- if block.settings.show_sale -%}<span class="pk-pcard__badge">Sale</span>{%- endif -%}
            </div>
            <div class="pk-pcard__body">
              <p class="pk-pcard__title">{{ block.settings.title }}</p>
              <div class="pk-pcard__prices">
                <span class="pk-pcard__price">₹{{ block.settings.price }}</span>
                {%- if block.settings.compare_at != blank -%}
                  <span class="pk-pcard__compare">₹{{ block.settings.compare_at }}</span>
                {%- endif -%}
              </div>
            </div>
          </a>
          <div class="pk-pcard__body" style="padding-top:0;">
            <button type="button" class="pk-pcard__add" data-pk-add-to-cart data-pk-product='{{ product_data | strip }}'>Add to Cart</button>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- for entry in defaults -%}
        {%- assign parts = entry | split: '|' -%}
        {%- capture product_data -%}
          {"id":{{ forloop.index | json }},"title":{{ parts[1] | json }},"price":{{ parts[2] | json }},"compareAt":{{ parts[3] | json }},"image":""}
        {%- endcapture -%}
        <div class="pk-pcard">
          <a href="/pages/product" style="text-decoration:none; color:inherit;">
            <div class="pk-pcard__media">
              {%- render 'pankui-placeholder', shape: parts[0] -%}
              <span class="pk-pcard__badge">Sale</span>
            </div>
            <div class="pk-pcard__body">
              <p class="pk-pcard__title">{{ parts[1] }}</p>
              <div class="pk-pcard__prices">
                <span class="pk-pcard__price">₹{{ parts[2] }}</span>
                <span class="pk-pcard__compare">₹{{ parts[3] }}</span>
              </div>
            </div>
          </a>
          <div class="pk-pcard__body" style="padding-top:0;">
            <button type="button" class="pk-pcard__add" data-pk-add-to-cart data-pk-product='{{ product_data | strip }}'>Add to Cart</button>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Pankui featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (optional)" },
    { "type": "text", "id": "heading", "label": "Heading (optional)" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Product name" },
        { "type": "image_picker", "id": "image", "label": "Image (upload here)" },
        { "type": "select", "id": "shape", "label": "Placeholder shape (used if no image)", "options": [
          { "value": "canister", "label": "Canister" },
          { "value": "wide-jar", "label": "Wide jar" },
          { "value": "spice-rack", "label": "Spice rack" }
        ], "default": "canister" },
        { "type": "text", "id": "price", "label": "Price (₹)", "default": "499" },
        { "type": "text", "id": "compare_at", "label": "Original price (₹) — optional, shows strikethrough" },
        { "type": "checkbox", "id": "show_sale", "label": "Show Sale badge", "default": true },
        { "type": "url", "id": "link", "label": "Product link", "default": "/pages/product" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [{ "name": "Pankui featured products" }]
}
{% endschema %}
