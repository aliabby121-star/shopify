{{ 'pankui.css' | asset_url | stylesheet_tag }}

<section class="pk pk-page">
  <div class="pk-wrap">
    <p class="pk-eyebrow" style="text-align:center; margin-bottom:18px;">Our story</p>

    <div class="pk-about__hero">
      <div>
        <p class="pk-about__quote">&ldquo;We make the containers we wished existed for our own kitchens.&rdquo;</p>
        <p class="pk-about__body">Pankui was started in 2025 by a design-led team in Bengaluru, tired of choosing between cheap and ugly or expensive and imported. Every piece is built for Indian kitchens, Indian humidity, Indian pantries.</p>
      </div>
      <div class="pk-about__media">{%- render 'pankui-placeholder', shape: 'spice-rack' -%}</div>
    </div>

    <div class="pk-pillars">
      <div>
        <svg class="pk-pillar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4l16 16M4 20L20 4"/></svg>
        <p class="pk-pillar__title">Thoughtful design</p>
        <p class="pk-pillar__desc">Considered for how Indian kitchens actually work.</p>
      </div>
      <div>
        <svg class="pk-pillar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M8 12h8"/></svg>
        <p class="pk-pillar__title">Quality materials</p>
        <p class="pk-pillar__desc">Food-safe ceramic and real wood, no shortcuts.</p>
      </div>
      <div>
        <svg class="pk-pillar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3l9 4-9 4-9-4 9-4zM3 11l9 4 9-4M3 15l9 4 9-4"/></svg>
        <p class="pk-pillar__title">Made for India</p>
        <p class="pk-pillar__desc">For our humidity, our spices, our habits.</p>
      </div>
      <div>
        <svg class="pk-pillar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="6" width="16" height="14" rx="2"/><path d="M8 10h8M8 14h8M8 18h5"/></svg>
        <p class="pk-pillar__title">Built to last</p>
        <p class="pk-pillar__desc">Make it once, keep it for a lifetime.</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Pankui about", "settings": [], "presets": [{ "name": "Pankui about" }] }
{% endschema %}
