{{ 'pankui.css' | asset_url | stylesheet_tag }}

<section class="pk pk-announcement">
  <div class="pk-announcement__row">
    {%- for block in section.blocks -%}
      <span class="pk-announcement__item" {{ block.shopify_attributes }}>
        {%- case block.settings.icon -%}
        {%- when 'truck' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        {%- when 'shield' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
        {%- when 'returns' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/></svg>
        {%- else -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/></svg>
        {%- endcase -%}
        {{ block.settings.text }}
      </span>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Pankui announcement bar",
  "settings": [],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (shipping)" },
            { "value": "shield", "label": "Shield (trust)" },
            { "value": "returns", "label": "Returns (circular arrow)" }
          ],
          "default": "truck"
        },
        { "type": "text", "id": "text", "label": "Text", "default": "Free shipping on orders above ₹999" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pankui announcement bar",
      "blocks": [
        { "type": "item", "settings": { "icon": "truck", "text": "Free shipping on orders above ₹999" } },
        { "type": "item", "settings": { "icon": "shield", "text": "COD Available" } },
        { "type": "item", "settings": { "icon": "returns", "text": "Easy Returns" } }
      ]
    }
  ]
}
{% endschema %}
