{{ 'pankui.css' | asset_url | stylesheet_tag }}

{%- liquid
  comment
  Title fallback chain: real collection title → page title → "Home & Kitchen"
  Render priority for the product grid:
    1. User-added product blocks (theme editor) ← highest
    2. Real Shopify collection.products
    3. Static placeholder cards (so the layout never looks empty)
  endcomment
  assign coll = collection
  assign page_title_fallback = ''
  if page and page.title != blank
    assign page_title_fallback = page.title
  endif
  assign coll_title = coll.title | default: page_title_fallback | default: 'Home & Kitchen'

  assign has_blocks = false
  if section.blocks.size > 0
    assign has_blocks = true
  endif
  assign use_real = false
  if has_blocks == false and coll.products.size > 0
    assign use_real = true
  endif
-%}

{%- assign placeholder_products = 'wide-jar|Air-Tight Storage Containers Set|499|799,wide-jar|Fridge Containers (6 Pack)|699|1199,canister|Modular Pantry Jars|349|499,spice-rack|Bamboo Chopping Board|349|549,canister|Ceramic Spice Jars|249|399,wide-jar|Modular Pantry Set|899|1299' | split: ',' -%}

{%- if has_blocks -%}
  {%- assign total_count = section.blocks.size -%}
{%- elsif use_real -%}
  {%- assign total_count = coll.all_products_count -%}
{%- else -%}
  {%- assign total_count = placeholder_products.size -%}
{%- endif -%}

<section class="pk pk-page">
  <div class="pk-wrap">
    <h1 class="pk-na__title">{{ coll_title }}</h1>

    <div class="pk-na__toolbar">
      <div class="pk-na__group">
        <span class="pk-na__label">Filter:</span>
        <button type="button" class="pk-na__dropdown" aria-haspopup="listbox">Availability</button>
        <button type="button" class="pk-na__dropdown" aria-haspopup="listbox">Price</button>
      </div>

      <div class="pk-na__group">
        <span class="pk-na__label">Sort by:</span>
        {%- if use_real -%}
          <select class="pk-na__select" onchange="window.location.search='?sort_by=' + this.value">
            <option value="manual"{% if coll.sort_by == 'manual' %} selected{% endif %}>Featured</option>
            <option value="best-selling"{% if coll.sort_by == 'best-selling' %} selected{% endif %}>Best selling</option>
            <option value="title-ascending"{% if coll.sort_by == 'title-ascending' %} selected{% endif %}>Alphabetically, A–Z</option>
            <option value="title-descending"{% if coll.sort_by == 'title-descending' %} selected{% endif %}>Alphabetically, Z–A</option>
            <option value="price-ascending"{% if coll.sort_by == 'price-ascending' %} selected{% endif %}>Price, low to high</option>
            <option value="price-descending"{% if coll.sort_by == 'price-descending' %} selected{% endif %}>Price, high to low</option>
            <option value="created-ascending"{% if coll.sort_by == 'created-ascending' %} selected{% endif %}>Date, old to new</option>
            <option value="created-descending"{% if coll.sort_by == 'created-descending' %} selected{% endif %}>Date, new to old</option>
          </select>
        {%- else -%}
          <select class="pk-na__select">
            <option>Date, new to old</option>
            <option>Featured</option>
            <option>Best selling</option>
            <option>Alphabetically, A–Z</option>
            <option>Alphabetically, Z–A</option>
            <option>Price, low to high</option>
            <option>Price, high to low</option>
          </select>
        {%- endif -%}
        <span class="pk-na__count">{{ total_count }} product{% if total_count != 1 %}s{% endif %}</span>
      </div>
    </div>

    <div class="pk-product-grid">
      {%- if has_blocks -%}
        {%- comment -%} User-uploaded products via theme editor {%- endcomment -%}
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.link | default: '#' }}" class="pk-product-card" {{ block.shopify_attributes }}>
            <div class="pk-placeholder" style="aspect-ratio: 1/1; padding: 0; position: relative;">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.image.alt | default: block.settings.title }}" style="width:100%;height:100%;object-fit:cover" loading="lazy">
              {%- else -%}
                {%- render 'pankui-placeholder', shape: 'canister' -%}
              {%- endif -%}
              {%- if block.settings.compare_at != blank -%}
                <span class="pk-pcard__badge">Sale</span>
              {%- endif -%}
            </div>
            <span class="pk-product-card__title">{{ block.settings.title }}</span>
            {%- if block.settings.description != blank -%}
              <span style="font-size:0.75rem; color:var(--pk-ink-soft); margin-top:-2px;">{{ block.settings.description }}</span>
            {%- endif -%}
            <span class="pk-product-card__price">
              <strong>₹{{ block.settings.price }}</strong>
              {%- if block.settings.compare_at != blank -%}
                <span style="text-decoration:line-through; color:var(--pk-ink-soft); margin-left:6px;">₹{{ block.settings.compare_at }}</span>
              {%- endif -%}
            </span>
          </a>
        {%- endfor -%}

      {%- elsif use_real -%}
        {%- comment -%} Real Shopify collection products {%- endcomment -%}
        {% paginate coll.products by 12 %}
          {%- for product in coll.products -%}
            <a href="{{ product.url }}" class="pk-product-card">
              <div class="pk-placeholder" style="aspect-ratio: 1/1; padding: 0;">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title }}" style="width:100%;height:100%;object-fit:cover" loading="lazy">
                {%- else -%}
                  {%- render 'pankui-placeholder', shape: 'canister' -%}
                {%- endif -%}
                {%- if product.compare_at_price > product.price -%}
                  <span class="pk-pcard__badge">Sale</span>
                {%- endif -%}
              </div>
              <span class="pk-product-card__title">{{ product.title }}</span>
              <span class="pk-product-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <strong>{{ product.price | money }}</strong>
                  <span style="text-decoration:line-through; color:var(--pk-ink-soft); margin-left:6px;">{{ product.compare_at_price | money }}</span>
                {%- else -%}
                  {{ product.price | money }}
                {%- endif -%}
              </span>
            </a>
          {%- endfor -%}

          {%- if paginate.pages > 1 -%}
            <div class="pk-na__pagination" style="grid-column: 1 / -1;">
              {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">‹</a>{%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}
                  <span class="is-current">{{ part.title }}</span>
                {%- else -%}
                  <span>{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}<a href="{{ paginate.next.url }}">›</a>{%- endif -%}
            </div>
          {%- endif -%}
        {% endpaginate %}

      {%- else -%}
        {%- comment -%} Placeholder cards so the page never looks empty {%- endcomment -%}
        {%- for entry in placeholder_products -%}
          {%- assign parts = entry | split: '|' -%}
          <a href="/collections/all" class="pk-product-card">
            <div class="pk-placeholder" style="aspect-ratio: 1/1; padding: 0; position: relative;">
              {%- render 'pankui-placeholder', shape: parts[0] -%}
              {%- if parts[3] != blank -%}<span class="pk-pcard__badge">Sale</span>{%- endif -%}
            </div>
            <span class="pk-product-card__title">{{ parts[1] }}</span>
            <span class="pk-product-card__price">
              <strong>₹{{ parts[2] }}</strong>
              {%- if parts[3] != blank -%}
                <span style="text-decoration:line-through; color:var(--pk-ink-soft); margin-left:6px;">₹{{ parts[3] }}</span>
              {%- endif -%}
            </span>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pankui collection",
  "settings": [],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Product image (upload here)" },
        { "type": "text", "id": "title", "label": "Product name", "default": "Product name" },
        { "type": "text", "id": "description", "label": "Short description (optional)" },
        { "type": "text", "id": "price", "label": "Price (₹)", "default": "499" },
        { "type": "text", "id": "compare_at", "label": "Original price / strikethrough (₹) — optional" },
        { "type": "url", "id": "link", "label": "Product link (optional)" }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [{ "name": "Pankui collection" }]
}
{% endschema %}
