{{ 'pankui.css' | asset_url | stylesheet_tag }}

<section class="pk pk-collections2">
  <div class="pk-collections2__head">
    <p class="pk-collections2__eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="pk-collections2__title">{{ section.settings.heading }}</h2>
    <div class="pk-collections2__divider" aria-hidden="true"><span>◆</span></div>
  </div>

  <div class="pk-collections2__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link | default: '#' }}" class="pk-collection2-card" {{ block.shopify_attributes }}>
        <div class="pk-collection2-card__media">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.image.alt | default: block.settings.title }}" loading="lazy">
          {%- else -%}
            <div class="pk-collection2-card__media-placeholder">
              {%- render 'pankui-placeholder', shape: block.settings.shape -%}
            </div>
          {%- endif -%}
        </div>
        <div class="pk-collection2-card__foot">
          <span class="pk-collection2-card__name">{{ block.settings.title }}</span>
          <span class="pk-collection2-card__arrow" aria-hidden="true">›</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Pankui collection cards",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "EXPLORE OUR RANGE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Collection" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "AIRTIGHT CONTAINERS" },
        { "type": "image_picker", "id": "image", "label": "Image (upload here)" },
        { "type": "select", "id": "shape", "label": "Placeholder shape (used when image is empty)", "options": [
          { "value": "canister", "label": "Canister" },
          { "value": "wide-jar", "label": "Wide jar" },
          { "value": "spice-rack", "label": "Spice rack" }
        ], "default": "canister" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Pankui collection cards",
      "blocks": [
        { "type": "card", "settings": { "title": "AIRTIGHT CONTAINERS", "shape": "canister" } },
        { "type": "card", "settings": { "title": "FRIDGE CONTAINERS", "shape": "wide-jar" } },
        { "type": "card", "settings": { "title": "STORAGE SETS", "shape": "canister" } },
        { "type": "card", "settings": { "title": "MODULAR CONTAINERS", "shape": "wide-jar" } },
        { "type": "card", "settings": { "title": "TEA, COFFEE & SUGAR SETS", "shape": "canister" } },
        { "type": "card", "settings": { "title": "KITCHEN ORGANIZERS", "shape": "spice-rack" } }
      ]
    }
  ]
}
{% endschema %}
