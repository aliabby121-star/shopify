{{ 'pankui.css' | asset_url | stylesheet_tag }}

<section class="pk pk-collections">
  <div class="pk-wrap">
    <div class="pk-collections__head">
      <p class="pk-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="pk-collections__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="pk-collection-card" {{ block.shopify_attributes }}>
          {%- render 'pankui-placeholder', label: block.settings.label, shape: block.settings.shape -%}
          <span class="pk-collection-card__index">{{ block.settings.index }}</span>
          <span class="pk-collection-card__title">{{ block.settings.title }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pankui collection cards",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated for you" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by collection" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "text", "id": "index", "label": "Index", "default": "01 · Spice" },
        { "type": "text", "id": "title", "label": "Title", "default": "For seasoning" },
        { "type": "text", "id": "label", "label": "Image label", "default": "" },
        { "type": "select", "id": "shape", "label": "Shape", "options": [
          { "value": "canister", "label": "Canister" },
          { "value": "wide-jar", "label": "Wide jar" },
          { "value": "spice-rack", "label": "Spice rack" }
        ], "default": "canister" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pankui collection cards",
      "blocks": [
        { "type": "card", "settings": { "index": "01 · Spice", "title": "For seasoning", "shape": "spice-rack" } },
        { "type": "card", "settings": { "index": "02 · Pantry", "title": "For staples", "shape": "canister" } },
        { "type": "card", "settings": { "index": "03 · Fridge", "title": "For produce", "shape": "wide-jar" } }
      ]
    }
  ]
}
{% endschema %}
