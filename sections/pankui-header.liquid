{{ 'pankui.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign current_path = request.path | default: '/'
-%}

<header class="pk pk-topnav">
  <div class="pk-topnav__row">
    <div class="pk-topnav__left">
      <button type="button" class="pk-topnav__icon" aria-label="Open menu" aria-controls="pk-drawer" data-pk-drawer-open>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>

    <a href="/" class="pk-topnav__center" aria-label="{{ shop.name }}">
      <span class="pk-topnav__brand">{{ section.settings.brand }}</span>
      {%- if section.settings.tagline != blank -%}
        <span class="pk-topnav__tagline">{{ section.settings.tagline }}</span>
      {%- endif -%}
    </a>

    <div class="pk-topnav__right">
      <a href="/search" class="pk-topnav__icon" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      </a>
      <div class="pk-topnav__social">
        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}" class="pk-topnav__icon" aria-label="Facebook" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13.5 22v-8h2.7l.4-3.1h-3.1V9c0-.9.3-1.5 1.6-1.5h1.6V4.7c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.4-4 4.1v2.2H7.6V14h2.7v8h3.2z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" class="pk-topnav__icon" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.youtube_url != blank -%}
          <a href="{{ section.settings.youtube_url }}" class="pk-topnav__icon" aria-label="YouTube" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21.6 7.2a2.5 2.5 0 0 0-1.8-1.8C18.3 5 12 5 12 5s-6.3 0-7.8.4A2.5 2.5 0 0 0 2.4 7.2 26 26 0 0 0 2 12a26 26 0 0 0 .4 4.8 2.5 2.5 0 0 0 1.8 1.8c1.5.4 7.8.4 7.8.4s6.3 0 7.8-.4a2.5 2.5 0 0 0 1.8-1.8c.3-1.6.4-3.2.4-4.8s-.1-3.2-.4-4.8zM10 15V9l5 3-5 3z"/></svg>
          </a>
        {%- endif -%}
      </div>
      <a href="{{ routes.account_url }}" class="pk-topnav__icon" aria-label="Account">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg>
      </a>
      <a href="/cart" class="pk-topnav__icon pk-topnav__cart" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6h15l-1.5 9H8z"/><path d="M6 6 5 3H2"/><circle cx="9" cy="20" r="1.5"/><circle cx="18" cy="20" r="1.5"/></svg>
        <span class="pk-topnav__cart-badge">{{ cart.item_count | default: 0 }}</span>
      </a>
    </div>
  </div>
</header>

{%- if section.blocks.size > 0 -%}
  <nav class="pk pk-topnav__menu" aria-label="Primary">
    <div class="pk-topnav__menu-row">
      {%- for block in section.blocks -%}
        {%- assign tab_link = block.settings.link | default: '/' -%}
        {%- assign is_active = false -%}
        {%- if tab_link == '/' and current_path == '/' -%}
          {%- assign is_active = true -%}
        {%- elsif tab_link != '/' and current_path contains tab_link -%}
          {%- assign is_active = true -%}
        {%- endif -%}
        <a href="{{ tab_link }}"
           class="pk-topnav__tab{% if is_active %} is-active{% endif %}"
           {{ block.shopify_attributes }}>
          {{ block.settings.label }}
        </a>
      {%- endfor -%}
    </div>
  </nav>
{%- endif -%}

{%- comment -%} Off-canvas drawer (hamburger menu) {%- endcomment -%}
<div id="pk-drawer" class="pk-drawer pk" role="dialog" aria-modal="true" aria-label="Main menu" aria-hidden="true">
  <div class="pk-drawer__overlay" data-pk-drawer-close></div>
  <aside class="pk-drawer__panel">
    <div class="pk-drawer__head">
      <span class="pk-drawer__brand">{{ section.settings.brand }}</span>
      <button type="button" class="pk-drawer__close" aria-label="Close menu" data-pk-drawer-close>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>

    <ul class="pk-drawer__nav">
      {%- for block in section.blocks -%}
        {%- assign tab_link = block.settings.link | default: '/' -%}
        {%- assign is_active = false -%}
        {%- if tab_link == '/' and current_path == '/' -%}
          {%- assign is_active = true -%}
        {%- elsif tab_link != '/' and current_path contains tab_link -%}
          {%- assign is_active = true -%}
        {%- endif -%}
        <li>
          <a href="{{ tab_link }}" class="{% if is_active %}is-active{% endif %}">{{ block.settings.label }}</a>
        </li>
      {%- endfor -%}
      <li><a href="{{ routes.account_url }}">My Account</a></li>
      <li><a href="/cart">Cart</a></li>
    </ul>

    <div class="pk-drawer__foot">
      Need help? <a href="mailto:hello@pankui.in">hello@pankui.in</a>
    </div>
  </aside>
</div>

<script>
  (function () {
    var drawer = document.getElementById('pk-drawer');
    if (!drawer) return;
    var openBtns = document.querySelectorAll('[data-pk-drawer-open]');
    var closeEls = drawer.querySelectorAll('[data-pk-drawer-close]');

    function openDrawer() {
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      document.body.classList.add('pk-drawer-open');
    }
    function closeDrawer() {
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('pk-drawer-open');
    }

    openBtns.forEach(function (b) { b.addEventListener('click', openDrawer); });
    closeEls.forEach(function (b) { b.addEventListener('click', closeDrawer); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && drawer.classList.contains('is-open')) closeDrawer();
    });
  })();
</script>

{% schema %}
{
  "name": "Pankui header",
  "settings": [
    { "type": "text", "id": "brand", "label": "Brand", "default": "pankui" },
    { "type": "text", "id": "tagline", "label": "Tagline (small text under logo, optional)", "default": "" },
    { "type": "header", "content": "Social icons (right side)" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "youtube_url", "label": "YouTube URL" }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Nav tab",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Home" },
        { "type": "url", "id": "link", "label": "Link", "default": "/" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Pankui header",
      "blocks": [
        { "type": "tab", "settings": { "label": "Home", "link": "/" } },
        { "type": "tab", "settings": { "label": "New Arrivals", "link": "/collections/new-arrivals" } },
        { "type": "tab", "settings": { "label": "Home & Kitchen", "link": "/collections/all" } },
        { "type": "tab", "settings": { "label": "About Us", "link": "/pages/about" } },
        { "type": "tab", "settings": { "label": "Contact Us", "link": "/pages/contact" } }
      ]
    }
  ]
}
{% endschema %}
