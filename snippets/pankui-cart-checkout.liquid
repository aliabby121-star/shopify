{%- comment -%}
  Pankui — site-wide slide-out cart drawer + Buy Now (GoKwik-style) modal.
  Cart persists in localStorage. Defensive global functions on window.
{%- endcomment -%}

<div id="pk-cd" class="pk-cd" role="dialog" aria-modal="true" aria-label="Your cart" aria-hidden="true">
  <div class="pk-cd__overlay" data-pk-cd-close></div>
  <aside class="pk-cd__panel">
    <header class="pk-cd__head">
      <h2>Your cart</h2>
      <button type="button" class="pk-cd__close" aria-label="Close cart" data-pk-cd-close>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </header>

    <div class="pk-cd__cols"><span>Product</span><span>Total</span></div>

    <div class="pk-cd__items" id="pk-cd-items">
      <div class="pk-cd__empty">Your cart is empty.</div>
    </div>

    <footer class="pk-cd__foot">
      <button type="button" class="pk-cd__notes-toggle" onclick="this.nextElementSibling.hidden=!this.nextElementSibling.hidden">
        Order special instructions
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <textarea hidden style="width:100%; padding:10px; border:1px solid var(--pk-line-strong); border-radius:4px; margin-top:6px; font:inherit; font-size:0.8125rem; resize:vertical; min-height:60px;"></textarea>

      <div class="pk-cd__subtotal">
        <span>Subtotal</span>
        <span id="pk-cd-subtotal">₹ 0.00</span>
      </div>
      <p class="pk-cd__tax-line">Tax included. Free Shipping with Cash on Delivery</p>
      <button type="button" class="pk-cd__checkout" onclick="window.pkBuyNow && window.pkBuyNow()">Checkout</button>
    </footer>
  </aside>
</div>

<div id="pk-bn" class="pk-bn" role="dialog" aria-modal="true" aria-label="Checkout" aria-hidden="true">
  <div class="pk-bn__overlay" data-pk-bn-close></div>
  <div class="pk-bn__panel">
    <div class="pk-bn__head">
      <button type="button" class="pk-bn__back" data-pk-bn-close>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M15 6l-6 6 6 6"/></svg>
      </button>
      <span class="pk-bn__brand">pankui</span>
      <span class="pk-bn__secure">
        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="10" width="14" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
        100% Secured Payment
      </span>
    </div>

    <div class="pk-bn__discount-banner">Extra Discount Available at Payment Step</div>

    <div class="pk-bn__body">
      <div class="pk-bn__summary">
        <div class="pk-bn__summary-left">
          <div class="pk-bn__summary-icon">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 6h15l-1.5 9H7z"/><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/></svg>
          </div>
          <div>
            <div class="pk-bn__summary-title">Order Summary</div>
            <div class="pk-bn__summary-saved"><strong id="pk-bn-saved">₹0</strong> saved so far</div>
          </div>
        </div>
        <div class="pk-bn__summary-right">
          <div><span id="pk-bn-items">0 items</span></div>
          <div>
            <span class="strike" id="pk-bn-compare">₹0</span>
            <span class="price" id="pk-bn-total">₹0</span>
          </div>
        </div>
      </div>

      <div class="pk-bn__coupon">
        <input type="text" placeholder="Enter coupon code">
        <div class="pk-bn__coupon-row">
          <span>🎟 10 coupons available</span>
          <a href="#">View All</a>
        </div>
      </div>

      <div class="pk-bn__field-card">
        <p class="pk-bn__field-title">👤 Login to continue</p>
        <div class="pk-bn__phone">
          <span>+91</span>
          <input type="tel" id="pk-bn-phone" placeholder="Enter Mobile Number" maxlength="10" inputmode="numeric">
        </div>
      </div>

      <div class="pk-bn__trust">
        <div class="pk-bn__powered">Powered by<strong>🛡️ GoKwik</strong></div>
        <div class="pk-bn__trust-line">⏱ Trusted by 1 million+ shoppers daily</div>
        <div class="pk-bn__badges">
          <span>🛡️ PCI DSS<br>Certified</span>
          <span>🔒 Secured<br>Payments</span>
          <span>✅ Verified<br>Merchant</span>
        </div>
      </div>
    </div>

    <label class="pk-bn__consent">
      <input type="checkbox">
      Send me order updates &amp; offers - (no spam)
    </label>

    <button type="button" class="pk-bn__continue" id="pk-bn-continue" disabled>Continue</button>
    <p class="pk-bn__legal">By proceeding, I agree to Gokwik's <a href="#">Privacy Policy</a> and <a href="#">T&amp;C</a>.</p>
  </div>
</div>

<script>
/* Pankui cart + checkout — defensive, no race conditions */
(function () {
  'use strict';
  console.log('[Pankui] cart/checkout snippet loading…');

  var KEY = 'pankui:cart';
  function load() { try { return JSON.parse(localStorage.getItem(KEY) || '[]'); } catch(e) { return []; } }
  function save(items) { try { localStorage.setItem(KEY, JSON.stringify(items)); } catch(e) {} }
  function money(n) { return '₹ ' + (Math.round(n * 100) / 100).toFixed(2); }
  function escapeHtml(s) { return String(s).replace(/[&<>"']/g, function(m){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m];}); }

  function el(id) { return document.getElementById(id); }

  function render() {
    var drawer = el('pk-cd'); if (!drawer) return;
    var itemsEl = el('pk-cd-items'); var subEl = el('pk-cd-subtotal');
    var items = load();
    if (!itemsEl || !subEl) return;
    if (!items.length) {
      itemsEl.innerHTML = '<div class="pk-cd__empty">Your cart is empty.</div>';
      subEl.textContent = money(0);
      updateBadge(0); return;
    }
    var subtotal = 0, totalCompare = 0, totalQty = 0;
    var html = items.map(function (it, i) {
      var line = (parseFloat(it.price) || 0) * (it.qty || 1);
      subtotal += line;
      totalCompare += (parseFloat(it.compareAt) || parseFloat(it.price) || 0) * (it.qty || 1);
      totalQty += (it.qty || 1);
      return '<div class="pk-cd__item">'+
        '<div class="pk-cd__item-img">'+(it.image ? '<img src="'+it.image+'" alt="">' : '')+'</div>'+
        '<div class="pk-cd__item-body">'+
          '<div class="pk-cd__item-title">'+escapeHtml(it.title || 'Product')+'</div>'+
          (it.variant ? '<div class="pk-cd__item-variant">'+escapeHtml(it.variant)+'</div>' : '')+
          '<div class="pk-cd__item-price">₹ '+(parseFloat(it.price) || 0).toFixed(2)+'</div>'+
          '<div class="pk-cd__item-qty" data-i="'+i+'">'+
            '<button type="button" data-step="-1">−</button>'+
            '<input type="text" value="'+(it.qty || 1)+'" inputmode="numeric" readonly>'+
            '<button type="button" data-step="1">+</button>'+
          '</div>'+
        '</div>'+
        '<div class="pk-cd__item-right">'+
          '<span class="pk-cd__item-total">₹ '+line.toFixed(2)+'</span>'+
          '<button type="button" class="pk-cd__item-remove" data-remove="'+i+'" aria-label="Remove">🗑</button>'+
        '</div>'+
      '</div>';
    }).join('');
    itemsEl.innerHTML = html;
    subEl.textContent = money(subtotal);
    updateBadge(totalQty);
    var bn = { saved: 'pk-bn-saved', compare: 'pk-bn-compare', total: 'pk-bn-total', items: 'pk-bn-items' };
    var saved = Math.max(0, totalCompare - subtotal);
    if (el(bn.saved)) el(bn.saved).textContent = '₹' + Math.round(saved);
    if (el(bn.compare)) el(bn.compare).textContent = '₹' + Math.round(totalCompare);
    if (el(bn.total)) el(bn.total).textContent = '₹' + Math.round(subtotal);
    if (el(bn.items)) el(bn.items).textContent = totalQty + ' item' + (totalQty === 1 ? '' : 's');
  }

  function updateBadge(n) {
    var badges = document.querySelectorAll('.pk-topnav__cart-badge');
    for (var i = 0; i < badges.length; i++) badges[i].textContent = n;
  }

  /* ===== Global API — defined IMMEDIATELY at script load ===== */
  window.pkOpenCart = function () {
    var d = el('pk-cd'); if (!d) { console.error('[Pankui] cart drawer not in DOM'); return; }
    render();
    d.classList.add('is-open'); d.setAttribute('aria-hidden','false');
    document.body.classList.add('pk-cd-open');
  };
  window.pkCloseCart = function () {
    var d = el('pk-cd'); if (!d) return;
    d.classList.remove('is-open'); d.setAttribute('aria-hidden','true');
    document.body.classList.remove('pk-cd-open');
  };
  window.pkBuyNow = function () {
    if (!load().length) { alert('Your cart is empty. Add a product first.'); return; }
    render();
    var m = el('pk-bn'); if (!m) { console.error('[Pankui] buy-now modal not in DOM'); return; }
    m.classList.add('is-open'); m.setAttribute('aria-hidden','false');
    document.body.classList.add('pk-bn-open');
  };
  window.pkCloseBuyNow = function () {
    var m = el('pk-bn'); if (!m) return;
    m.classList.remove('is-open'); m.setAttribute('aria-hidden','true');
    document.body.classList.remove('pk-bn-open');
  };
  window.pkAddToCart = function (product) {
    console.log('[Pankui] pkAddToCart called with', product);
    var items = load();
    var p = product || {};
    var key = (p.id || p.title || 'item') + '|' + (p.variant || '');
    var found = items.find ? items.find(function(i){ return ((i.id||i.title||'item') + '|' + (i.variant||'')) === key; }) : null;
    if (found) found.qty = (found.qty || 1) + (p.qty || 1);
    else items.push({ id:p.id||'', title:p.title||'Product', variant:p.variant||'', price:p.price||'0', compareAt:p.compareAt||'', image:p.image||'', qty:p.qty||1 });
    save(items);
    window.pkOpenCart();
  };

  function bind() {
    var drawer = el('pk-cd'); var modal = el('pk-bn');
    if (!drawer || !modal) { console.warn('[Pankui] drawer/modal not in DOM yet — retrying'); setTimeout(bind, 50); return; }

    // Close handlers
    drawer.querySelectorAll('[data-pk-cd-close]').forEach(function(b){ b.addEventListener('click', window.pkCloseCart); });
    modal.querySelectorAll('[data-pk-bn-close]').forEach(function(b){ b.addEventListener('click', window.pkCloseBuyNow); });
    document.addEventListener('keydown', function(e){
      if (e.key === 'Escape') {
        if (modal.classList.contains('is-open')) window.pkCloseBuyNow();
        else if (drawer.classList.contains('is-open')) window.pkCloseCart();
      }
    });

    // Drawer item qty/remove
    var itemsEl = el('pk-cd-items');
    if (itemsEl) {
      itemsEl.addEventListener('click', function (e) {
        var rem = e.target.closest('[data-remove]');
        if (rem) { var its = load(); its.splice(parseInt(rem.dataset.remove,10), 1); save(its); render(); return; }
        var step = e.target.closest('[data-step]');
        if (step) {
          var wrap = step.closest('[data-i]'); var i = parseInt(wrap.dataset.i, 10);
          var its2 = load(); its2[i].qty = Math.max(1, (its2[i].qty || 1) + parseInt(step.dataset.step, 10));
          save(its2); render();
        }
      });
    }

    // Phone → continue
    var phone = el('pk-bn-phone'); var cont = el('pk-bn-continue');
    if (phone && cont) {
      phone.addEventListener('input', function () {
        phone.value = phone.value.replace(/\D/g,'').slice(0,10);
        if (phone.value.length === 10) { cont.classList.add('is-active'); cont.disabled = false; }
        else { cont.classList.remove('is-active'); cont.disabled = true; }
      });
      cont.addEventListener('click', function () {
        if (cont.disabled) return;
        alert('OTP sent to +91 ' + phone.value + '. (Demo — connect to your payment provider to complete checkout.)');
      });
    }

    // Delegated PDP clicks
    document.addEventListener('click', function (e) {
      var add = e.target.closest('[data-pk-add-to-cart]');
      var buy = e.target.closest('[data-pk-buy-now]');
      var openCart = e.target.closest('[data-pk-cart-open]');
      if (add || buy) {
        e.preventDefault();
        var btn = add || buy;
        var data = {};
        try { data = JSON.parse(btn.getAttribute('data-pk-product') || '{}'); } catch (err) { console.error('[Pankui] bad product JSON', err); }
        var pdp = btn.closest('.pk-pdp__info') || document;
        var q = pdp.querySelector('.pk-pdp__qty input');
        var v = pdp.querySelector('.pk-pdp__variant.is-active');
        if (q) data.qty = Math.max(1, parseInt(q.value, 10) || 1);
        if (v) data.variant = v.textContent.trim();

        // Animation: flash "✓ Added" for 900ms before opening drawer
        var originalText = btn.textContent;
        btn.classList.add('is-added');
        btn.textContent = 'Added';
        setTimeout(function () {
          btn.classList.remove('is-added');
          btn.textContent = originalText;
        }, 900);

        window.pkAddToCart(data);
        if (buy) window.pkBuyNow();
      } else if (openCart) {
        e.preventDefault(); window.pkOpenCart();
      }
    });

    // ===== Direct wire of PDP Add/Buy buttons (more reliable than section's inline script) =====
    function wirePdpButtons() {
      var addBtns = document.querySelectorAll('.pk-pdp__add');
      var buyBtns = document.querySelectorAll('.pk-pdp__buy');
      console.log('[Pankui] wiring PDP buttons — add:', addBtns.length, 'buy:', buyBtns.length);

      function readPdpProduct(btn) {
        var pdp = btn.closest('.pk-pdp__info') || document.querySelector('.pk-pdp__info') || document;
        var titleEl = pdp.querySelector('.pk-pdp__title');
        var priceEl = pdp.querySelector('.pk-pdp__price');
        var compareEl = pdp.querySelector('.pk-pdp__price-compare');
        var imgEl = document.querySelector('.pk-pdp__main img');
        var qi = pdp.querySelector('.pk-pdp__qty input');
        var v  = pdp.querySelector('.pk-pdp__variant.is-active');
        return {
          id: location.pathname,
          title: titleEl ? titleEl.textContent.trim() : 'Product',
          price: priceEl ? (priceEl.textContent.match(/[\d,.]+/) || ['0'])[0].replace(/,/g, '') : '0',
          compareAt: compareEl ? (compareEl.textContent.match(/[\d,.]+/) || [''])[0].replace(/,/g, '') : '',
          image: imgEl ? imgEl.src : '',
          qty: qi ? Math.max(1, parseInt(qi.value, 10) || 1) : 1,
          variant: v ? v.textContent.trim() : ''
        };
      }
      function flash(btn) {
        var o = btn.textContent;
        btn.classList.add('is-added'); btn.textContent = 'Added';
        setTimeout(function(){ btn.classList.remove('is-added'); btn.textContent = o; }, 900);
      }

      addBtns.forEach(function (btn) {
        if (btn.__pkWired) return;
        btn.__pkWired = true;
        btn.addEventListener('click', function () {
          console.log('[Pankui] PDP Add to cart clicked');
          flash(btn);
          window.pkAddToCart(readPdpProduct(btn));
        });
      });
      buyBtns.forEach(function (btn) {
        if (btn.__pkWired) return;
        btn.__pkWired = true;
        btn.addEventListener('click', function () {
          console.log('[Pankui] PDP Buy now clicked');
          window.pkAddToCart(readPdpProduct(btn));
          window.pkBuyNow();
        });
      });
    }
    wirePdpButtons();

    // Refresh badge on init
    render();
    console.log('[Pankui] cart/checkout ready ✓');
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind);
  else bind();
})();
</script>
