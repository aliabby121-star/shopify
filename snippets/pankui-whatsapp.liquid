{%- comment -%}
  Pankui — sticky WhatsApp button.
  Reads number + visibility from theme settings (settings_schema.json `pk_whatsapp_*`).
  Falls back to hardcoded defaults below if those settings don't exist.
{%- endcomment -%}

{%- assign wa_number = settings.pk_whatsapp_number | default: '918826456887' -%}
{%- assign wa_enabled = settings.pk_whatsapp_enabled -%}
{%- if wa_enabled == nil -%}{%- assign wa_enabled = true -%}{%- endif -%}
{%- assign wa_text = settings.pk_whatsapp_text | default: 'Hi! I have a question about Pankui.' | url_encode -%}

{%- if wa_enabled -%}
  <a class="pk-wa"
     href="https://wa.me/{{ wa_number }}?text={{ wa_text }}"
     target="_blank" rel="noopener"
     aria-label="Chat on WhatsApp">
    <svg viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
      <path d="M16 3C9.4 3 4 8.4 4 15c0 2.3.6 4.5 1.8 6.4L4 29l7.8-1.8c1.8 1 3.9 1.5 6 1.5h.2C24.6 28.7 30 23.3 30 16.7 30 13.4 28.7 10.2 26.4 7.9 24.1 5.6 20.3 3 16 3zm0 23.2h-.1c-1.9 0-3.7-.5-5.3-1.5l-.4-.2-4.6 1 1-4.5-.3-.5C5.4 19 4.9 17 4.9 15 4.9 9 9.9 4 16 4c2.9 0 5.6 1.1 7.7 3.2 2.1 2 3.2 4.8 3.2 7.7 0 6-5 11.2-11 11.3zm6.4-8.4c-.3-.2-2-1-2.3-1.1-.3-.1-.5-.2-.8.2-.2.3-.9 1.1-1.1 1.3-.2.2-.4.2-.7.1-.3-.2-1.4-.5-2.6-1.6-1-.9-1.6-2-1.8-2.3-.2-.3 0-.5.1-.6.1-.1.3-.4.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.8-1-2.5-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1.1 1-1.1 2.6 0 1.5 1.1 3 1.3 3.2.2.3 2.2 3.4 5.3 4.8.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.4.2-.7.2-1.3.2-1.4-.1-.1-.2-.2-.4-.3z"/>
    </svg>
  </a>
{%- endif -%}
