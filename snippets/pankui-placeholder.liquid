{%- comment -%}
  Pankui — tan canister placeholder.
  Renders an SVG of a labelled jar so the mockup layout reads without real images.

  Accepts:
    label   — short text rendered on the canister (e.g. "TEA")
    class   — extra CSS class to merge onto the wrapping div
    shape   — "canister" (default) | "wide-jar" | "spice-rack"
{%- endcomment -%}
{%- assign _label = label | default: '' -%}
{%- assign _class = class | default: '' -%}
{%- assign _shape = shape | default: 'canister' -%}

<div class="pk-placeholder {{ _class }}">
  {%- case _shape -%}
  {%- when 'wide-jar' -%}
    <svg viewBox="0 0 120 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="14" y="12" width="92" height="14" rx="3" fill="#6b4f33"/>
      <rect x="10" y="26" width="100" height="68" rx="6" fill="#efe1c7"/>
      <rect x="22" y="44" width="76" height="20" fill="#ffffff" opacity="0.55"/>
      {%- if _label != blank -%}
        <text x="60" y="60" text-anchor="middle" font-family="Georgia, serif" font-size="11" fill="#2a2522" letter-spacing="2">{{ _label | upcase }}</text>
      {%- endif -%}
    </svg>
  {%- when 'spice-rack' -%}
    <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="6" y="14" width="108" height="92" rx="4" fill="#e7d6b8"/>
      {%- for i in (0..3) -%}
        {%- assign cx = i | times: 26 | plus: 22 -%}
        <rect x="{{ cx | minus: 9 }}" y="34" width="18" height="22" rx="2" fill="#efe1c7"/>
        <rect x="{{ cx | minus: 9 }}" y="66" width="18" height="22" rx="2" fill="#efe1c7"/>
        <circle cx="{{ cx }}" cy="34" r="3" fill="#6b4f33"/>
        <circle cx="{{ cx }}" cy="66" r="3" fill="#6b4f33"/>
      {%- endfor -%}
    </svg>
  {%- else -%}
    <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <ellipse cx="50" cy="14" rx="32" ry="6" fill="#6b4f33"/>
      <rect x="18" y="14" width="64" height="12" fill="#6b4f33"/>
      <rect x="14" y="26" width="72" height="86" rx="6" fill="#efe1c7"/>
      <rect x="26" y="48" width="48" height="22" fill="#ffffff" opacity="0.55"/>
      {%- if _label != blank -%}
        <text x="50" y="63" text-anchor="middle" font-family="Georgia, serif" font-size="11" fill="#2a2522" letter-spacing="3">{{ _label | upcase }}</text>
      {%- endif -%}
    </svg>
  {%- endcase -%}
</div>
