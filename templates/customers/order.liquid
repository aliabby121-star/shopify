{% comment %} Pankui — single order view {% endcomment %}

<div class="pankui-account page-width">
  <aside class="pankui-account__nav">
    <h5 class="pankui-account__nav-heading">My account</h5>
    <ul>
      <li><a href="{{ routes.account_url }}">Dashboard</a></li>
      <li><a href="{{ routes.account_url }}/orders" aria-current="page">Orders</a></li>
      <li><a href="/pages/wishlist">Wishlist</a></li>
      <li><a href="{{ routes.account_addresses_url }}">Addresses</a></li>
      <li><a href="{{ routes.account_url }}">Account details</a></li>
      <li><a href="{{ routes.account_logout_url }}">Logout</a></li>
    </ul>
  </aside>

  <main class="pankui-account__main">
    <h1 class="pankui-account__title">Order {{ order.name }}</h1>
    <p class="pankui-account__meta">Placed on {{ order.created_at | date: '%B %d, %Y' }}</p>

    <section class="pankui-account__section">
      <header><h2>Status</h2></header>
      <p>{{ order.fulfillment_status_label }} &middot; {{ order.financial_status_label }}</p>
    </section>

    <section class="pankui-account__section">
      <header><h2>Items</h2></header>
      <table class="pankui-account__orders">
        <thead>
          <tr><th>Product</th><th>Qty</th><th>Total</th></tr>
        </thead>
        <tbody>
          {%- for line in order.line_items -%}
            <tr>
              <td>{{ line.title }}</td>
              <td>{{ line.quantity }}</td>
              <td>{{ line.final_line_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
        <tfoot>
          <tr><td colspan="2">Subtotal</td><td>{{ order.subtotal_price | money }}</td></tr>
          <tr><td colspan="2">Shipping</td><td>{{ order.shipping_price | money }}</td></tr>
          <tr><td colspan="2"><strong>Total</strong></td><td><strong>{{ order.total_price | money }}</strong></td></tr>
        </tfoot>
      </table>
    </section>

    <section class="pankui-account__section">
      <header><h2>Shipping address</h2></header>
      {%- if order.shipping_address -%}
        <address>{{ order.shipping_address | format_address }}</address>
      {%- endif -%}
    </section>
  </main>
</div>

<style>
  .pankui-account { display: grid; grid-template-columns: 220px 1fr; gap: 3rem; padding-block: 3rem; }
  .pankui-account__nav-heading { font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 1rem; }
  .pankui-account__nav ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .pankui-account__nav a { font-size: 0.875rem; text-decoration: none; }
  .pankui-account__nav a[aria-current="page"] { font-weight: 600; }
  .pankui-account__title { font-size: 1.5rem; margin: 0 0 0.25rem; }
  .pankui-account__meta { font-size: 0.8125rem; opacity: 0.7; margin: 0 0 2rem; }
  .pankui-account__section { margin-bottom: 2.5rem; }
  .pankui-account__section header { margin-bottom: 1rem; }
  .pankui-account__section h2 { font-size: 1rem; margin: 0; }
  .pankui-account__orders { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .pankui-account__orders th, .pankui-account__orders td { text-align: left; padding: 0.75rem 0; border-bottom: 1px solid rgba(0,0,0,0.08); }
  @media (max-width: 749px) { .pankui-account { grid-template-columns: 1fr; gap: 2rem; } }
</style>
