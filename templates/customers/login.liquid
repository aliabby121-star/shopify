{{ 'pankui.css' | asset_url | stylesheet_tag }}

<section class="pk pk-page">
  <div class="pk-wrap">
    <div class="pk-auth">
      <div class="pk-auth__panel">
        <h1>Login</h1>
        {%- form 'customer_login', class: 'pk-auth__form' -%}
          {%- if form.errors -%}
            <p class="pk-auth__hint" style="color:#b3261e;">{{ form.errors | default_errors }}</p>
          {%- endif -%}
          <div class="pk-field">
            <label for="LoginEmail">Email address</label>
            <input class="pk-input" id="LoginEmail" type="email" name="customer[email]" autocomplete="email" required>
          </div>
          <div class="pk-field">
            <label for="LoginPassword">Password</label>
            <input class="pk-input" id="LoginPassword" type="password" name="customer[password]" autocomplete="current-password" required>
          </div>
          <a class="pk-auth__forgot" href="{{ routes.account_recover_url }}">Forgot password?</a>
          <button type="submit" class="pk-btn pk-btn--primary pk-btn--block">Login</button>
        {%- endform -%}

        <div class="pk-auth__divider"><span>or</span></div>
        <button type="button" class="pk-auth__social">G &nbsp; Continue with Google</button>
        <button type="button" class="pk-auth__social"> &nbsp; Continue with Apple</button>
      </div>

      <div class="pk-auth__panel">
        <h1>Create account</h1>
        {%- form 'create_customer', class: 'pk-auth__form' -%}
          {%- if form.errors -%}
            <p class="pk-auth__hint" style="color:#b3261e;">{{ form.errors | default_errors }}</p>
          {%- endif -%}
          <div class="pk-field">
            <label for="RegName">Full name</label>
            <input class="pk-input" id="RegName" type="text" name="customer[first_name]" autocomplete="name" required>
          </div>
          <div class="pk-field">
            <label for="RegEmail">Email address</label>
            <input class="pk-input" id="RegEmail" type="email" name="customer[email]" autocomplete="email" required>
          </div>
          <div class="pk-field">
            <label for="RegPassword">Password</label>
            <input class="pk-input" id="RegPassword" type="password" name="customer[password]" autocomplete="new-password" required>
          </div>
          <button type="submit" class="pk-btn pk-btn--primary pk-btn--block">Sign up</button>
        {%- endform -%}
        <p class="pk-auth__hint">Already have an account? <a href="#LoginEmail">Login</a></p>
      </div>
    </div>
  </div>
</section>
