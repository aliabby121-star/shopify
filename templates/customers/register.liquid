{% comment %} Pankui — create account {% endcomment %}

<div class="pankui-auth pankui-auth--single page-width">
  <div class="pankui-auth__panel">
    <h1 class="pankui-auth__title">Create account</h1>

    {%- form 'create_customer', class: 'pankui-auth__form' -%}
      {%- if form.errors -%}
        <div class="pankui-auth__errors">{{ form.errors | default_errors }}</div>
      {%- endif -%}

      <label for="RegisterFirstName">Full name</label>
      <input type="text" name="customer[first_name]" id="RegisterFirstName" autocomplete="name" required>

      <label for="RegisterEmail">Email address</label>
      <input type="email" name="customer[email]" id="RegisterEmail" autocomplete="email" required>

      <label for="RegisterPassword">Password</label>
      <input type="password" name="customer[password]" id="RegisterPassword" autocomplete="new-password" required>

      <button type="submit" class="button pankui-auth__submit">Sign up</button>
    {%- endform -%}

    <p class="pankui-auth__hint">Already have an account? <a href="{{ routes.account_login_url }}">Login</a></p>
  </div>
</div>

<style>
  .pankui-auth { padding-block: 4rem; }
  .pankui-auth--single { max-width: 28rem; margin: 0 auto; }
  .pankui-auth__panel { display: flex; flex-direction: column; gap: 0.75rem; }
  .pankui-auth__title { font-size: 1.5rem; margin: 0 0 1rem; }
  .pankui-auth__form { display: flex; flex-direction: column; gap: 0.75rem; }
  .pankui-auth__form label { font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.08em; }
  .pankui-auth__form input { padding: 0.75rem; border: 1px solid rgba(0,0,0,0.15); background: transparent; }
  .pankui-auth__submit { margin-top: 0.5rem; }
  .pankui-auth__hint { font-size: 0.8125rem; margin-top: 1rem; }
  .pankui-auth__errors { color: #b3261e; font-size: 0.8125rem; }
</style>
