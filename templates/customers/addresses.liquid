{% comment %} Pankui — saved addresses {% endcomment %}

<div class="pankui-account page-width">
  <aside class="pankui-account__nav">
    <h5 class="pankui-account__nav-heading">My account</h5>
    <ul>
      <li><a href="{{ routes.account_url }}">Dashboard</a></li>
      <li><a href="{{ routes.account_url }}/orders">Orders</a></li>
      <li><a href="/pages/wishlist">Wishlist</a></li>
      <li><a href="{{ routes.account_addresses_url }}" aria-current="page">Addresses</a></li>
      <li><a href="{{ routes.account_url }}">Account details</a></li>
      <li><a href="{{ routes.account_logout_url }}">Logout</a></li>
    </ul>
  </aside>

  <main class="pankui-account__main">
    <h1 class="pankui-account__title">Your addresses</h1>

    {%- if customer.addresses.size > 0 -%}
      <div class="pankui-account__address-grid">
        {%- for address in customer.addresses -%}
          <article class="pankui-account__address-card">
            {%- if address == customer.default_address -%}
              <p class="pankui-account__address-badge">Default</p>
            {%- endif -%}
            <address>{{ address | format_address }}</address>
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="pankui-account__empty">No saved addresses yet.</p>
    {%- endif -%}
  </main>
</div>

<style>
  .pankui-account { display: grid; grid-template-columns: 220px 1fr; gap: 3rem; padding-block: 3rem; }
  .pankui-account__nav-heading { font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 1rem; }
  .pankui-account__nav ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .pankui-account__nav a { font-size: 0.875rem; text-decoration: none; }
  .pankui-account__nav a[aria-current="page"] { font-weight: 600; }
  .pankui-account__title { font-size: 1.5rem; margin: 0 0 2rem; }
  .pankui-account__address-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.5rem; }
  .pankui-account__address-card { border: 1px solid rgba(0,0,0,0.08); padding: 1.25rem; font-size: 0.875rem; }
  .pankui-account__address-badge { font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 0.5rem; opacity: 0.7; }
  .pankui-account__empty { font-size: 0.875rem; opacity: 0.8; }
  @media (max-width: 749px) { .pankui-account { grid-template-columns: 1fr; gap: 2rem; } }
</style>
