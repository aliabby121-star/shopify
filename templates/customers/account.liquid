{{ 'pankui.css' | asset_url | stylesheet_tag }}

{%- assign orders = 'PKU1024|May 10, 2025|Delivered|2268,PKU0987|Apr 28, 2025|Delivered|1749,PKU0955|Apr 15, 2025|Delivered|699' | split: ',' -%}

<section class="pk pk-page">
  <div class="pk-wrap">
    <div class="pk-account">
      <aside class="pk-account__nav">
        <h5>My account</h5>
        <ul>
          <li><a href="{{ routes.account_url }}" class="is-active">Dashboard</a></li>
          <li><a href="{{ routes.account_url }}/orders">Orders</a></li>
          <li><a href="/pages/wishlist">Wishlist</a></li>
          <li><a href="{{ routes.account_addresses_url }}">Addresses</a></li>
          <li><a href="{{ routes.account_url }}">Account details</a></li>
          <li><a href="{{ routes.account_logout_url }}">Logout</a></li>
        </ul>
      </aside>

      <main>
        <h1 class="pk-account__title">Dashboard</h1>
        <p class="pk-account__welcome">Welcome back, {{ customer.first_name | default: 'Ananya' }} 👋</p>

        <div class="pk-account__section-head">
          <h3>From your orders</h3>
          <a href="{{ routes.account_url }}/orders" class="pk-link" style="font-size:0.75rem;">View all orders</a>
        </div>

        <table class="pk-account__orders">
          <tbody>
            {%- for entry in orders -%}
              {%- assign parts = entry | split: '|' -%}
              <tr>
                <td><div class="pk-account__order-thumb">{%- render 'pankui-placeholder', shape: 'canister' -%}</div></td>
                <td>
                  <div>Order #{{ parts[0] }}</div>
                  <small>{{ parts[1] }}</small>
                </td>
                <td class="pk-account__status">{{ parts[2] }}</td>
                <td><strong>₹{{ parts[3] }}</strong></td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </main>
    </div>
  </div>
</section>
